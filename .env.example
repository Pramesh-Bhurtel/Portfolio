# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — Firebase Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your actual values.
# .env is gitignored and NEVER committed to version control.
#
# Used by: Vite dev server (npm run dev)
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-YOUR_MEASUREMENT_ID

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — Cloudflare Worker Secrets
# ─────────────────────────────────────────────────────────────────────────────
# For production, do NOT use this file.
# Add the following as encrypted "Secrets" in:
#   Cloudflare Dashboard → Workers & Pages → portfolio
#   → Settings → Variables and Secrets → Add Secret
#
# Secret names to add (same values as above, without the VITE_ prefix):
#   FIREBASE_API_KEY
#   FIREBASE_AUTH_DOMAIN
#   FIREBASE_DATABASE_URL
#   FIREBASE_PROJECT_ID
#   FIREBASE_STORAGE_BUCKET
#   FIREBASE_MESSAGING_SENDER_ID
#   FIREBASE_APP_ID
#   FIREBASE_MEASUREMENT_ID
# ─────────────────────────────────────────────────────────────────────────────
